# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*~
*.swp

# Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Build output
node_modules/
/dist/
*.tsbuildinfo
vite.log

# Bundle artefacts — these are zip exports, regenerated on demand
# by scripts/bundle-skill.py. Keep the dir tracked (with .gitkeep) so
# contributors see where bundles go, but never commit the zips.
bundles/*.zip
!bundles/.gitkeep

# Temporary files
*.log

# Git temporary
.git/*.md
